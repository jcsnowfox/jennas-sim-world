{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "noEmit": false,
    "allowJs": false,
    "checkJs": false,
    "declaration": false,
    "outDir": "dist-ts",
    "rootDir": ".",
    "types": ["node", "vitest"],
    "skipLibCheck": true
  },
  "include": ["apps/**/*.ts", "packages/**/*.ts", "tests/**/*.ts"],
  "exclude": ["node_modules", "dist", "release", "dist-ts"]
}
